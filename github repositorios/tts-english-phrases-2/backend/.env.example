# ── TTS App ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Google Cloud TTS — create a key at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_TTS_API_KEY=<your Google Cloud TTS API key>
MAX_GENERATION_TIMEOUT_SECONDS=120

# ── Supabase Storage (audio files) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=audio-sessions
SESSION_TTL_HOURS=3

# ── Database (Supabase PostgreSQL — Transaction Pooler URL recommended)
# Format: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
MAGIC_LINK_EXPIRE_MINUTES=15

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/pages/auth/google/callback.html

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BILLING_MODE=checkout

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
APP_NAME=TTS English Phrases
SUPPORT_EMAIL=support@yourdomain.com
OWNER_EMAIL=you@yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8000
FRONTEND_ORIGIN=*
