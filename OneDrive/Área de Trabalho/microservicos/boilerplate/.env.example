# ─────────────────────────────────────────────
# EDIT PER PROJECT — application identity
# ─────────────────────────────────────────────
APP_NAME="My SaaS App"
FRONTEND_URL="http://localhost:3000"
SUPPORT_EMAIL="support@example.com"
OWNER_EMAIL="you@example.com"

# ─────────────────────────────────────────────
# Database (Supabase / PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://user:password@host:5432/dbname"

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080          # 7 days

MAGIC_LINK_EXPIRE_MINUTES=15

# Google OAuth — leave blank to disable
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="${FRONTEND_URL}/auth/google/callback"

# ─────────────────────────────────────────────
# Stripe  EDIT PER PROJECT
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Billing mode: "checkout" | "elements"
BILLING_MODE="checkout"

# ─────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@example.com"

# ─────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────
# Paywall mode: "modal" | "redirect"
PAYWALL_MODE="modal"

# Guest sessions: true | false
ENABLE_GUEST_SESSIONS="true"

# Number of guest actions before nudge banner
GUEST_NUDGE_AFTER=3

# ─────────────────────────────────────────────
# Rate limiting defaults (overridden per plan)
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=3600
